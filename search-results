<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cannonball – Search Results</title>
  <style>
    body { font-family: Arial, sans-serif; padding: 20px; line-height: 1.6; }
    h1 { margin-bottom: 20px; }
    .search-box { margin-bottom: 30px; }
    input { padding: 8px 12px; font-size: 16px; }
    button { padding: 8px 16px; cursor: pointer; }
    .results { margin-top: 20px; }
    .result-item { border: 1px solid #ccc; padding: 15px; margin-bottom: 15px; border-radius: 4px; }
    .no-results { color: #999; font-style: italic; }
  </style>
</head>
<body>

  <h1>Cannonball - Water Bodies Search</h1>
  
  <div class="search-box">
    <label for="areaCode">Enter Area/Location:</label><br><br>
    <input type="text" id="areaCode" placeholder="e.g., Oceanside, La Jolla, Carlsbad" />
    <button onclick="searchResults()">Search</button>
  </div>

  <div class="results" id="results"></div>

  // here's the results of the search. just copy line 34 and change the values to the next water body we have in the list. 
  <script>
    const waterBodies = [
      { location: "Scripps Ranch", waterbody: "Miramar Reservoir", swimmability: 1, drinkable: "Yes", activities: "swimming/wading/bathing/diving prohibited" },
    ];

    function searchResults() {
      const query = document.getElementById("areaCode").value.toLowerCase().trim();
      const resultsDiv = document.getElementById("results");
      
      if (!query) {
        resultsDiv.innerHTML = '<p class="no-results">Please enter a search term.</p>';
        return;
      }

      const matches = waterBodies.filter(item => 
        item.location.toLowerCase().includes(query) || 
        item.waterbody.toLowerCase().includes(query)
      );

      if (matches.length === 0) {
        resultsDiv.innerHTML = '<p class="no-results">No results found for "' + query + '"</p>';
        return;
      }

      let html = '<h2>Results for "' + query + '" (' + matches.length + ' found):</h2>';
      matches.forEach(item => {
        html += `
        <div class="result-item">
          <h3>${item.waterbody}</h3>
          <p><strong>Location:</strong> ${item.location}</p>
          <p><strong>Swimmability:</strong> ${item.swimmability}/10</p>
          <p><strong>Drinkable:</strong> ${item.drinkable}</p>
          <p><strong>Activities:</strong> ${item.activities}</p>
        </div>
        `;
      });
      resultsDiv.innerHTML = html;
    }
  // we dont have area codes set up in the database for the water bodies but i saw laila include it as a feature of the search. not sure how we want to go about it but if we do use area codes, it's set up below. 
    document.getElementById("areaCode").addEventListener("keypress", function(e) {
      if (e.key === "Enter") searchResults();
    });
  </script>
  </div>

</body>
</html>
